# Gemini API Key (same one used in Vercel env)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase credentials (same ones used in .env.local)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: how many seconds between API calls (default: 5)
DELAY_SECONDS=5

# Optional legacy fallback if HOT_MAX_AGE_HOURS is not set
MAX_AGE_HOURS=24

# Hot ZIPs = recent searches, favorites, community activity
# Warm ZIPs = static seed coverage ZIPs
HOT_MAX_AGE_HOURS=24
WARM_MAX_AGE_HOURS=168

# How many ZIPs to consider per signal source on each run
MAX_SEED_ZIPS=150
MAX_RECENT_SEARCH_ZIPS=125
MAX_FAVORITE_ZIPS=75
MAX_REPORT_ZIPS=75

# ── SEO Page Generator ──────────────────────────────────────────────
# GitHub Personal Access Token (needs 'repo' scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# GitHub repo to push SEO pages to (format: username/repo-name)
# Create a separate empty repo for this, e.g. "youruser/scanner-seo-pages"
# Connect it to a new Vercel project pointing at the repo root
GITHUB_REPO=tfs2006/scanner-seo-pages

# Canonical URL of the main app (no trailing slash)
SEO_SITE_URL=https://www.boyandascanner.com
